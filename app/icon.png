 match('Día 2','14:15','14:55','Pista 1','Infantil','Fase de grupos niños','A1','A2','INF-G-A-1'),match('Día 2','14:15','14:55','Pista 2','Infantil','Fase de grupos niños','B1','B2','INF-G-B-1'),
