te\":\"2053240259\",\"gateValue\":\"false\",\"ruleID\":\"5CIKroDnxAOVbZnindwslZ:5.00:1\"}],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1429888782\":{\"name\":\"1429888782\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"enabled\"],\"group_name\":\"Control\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"3983984123\":{\"name\":\"3983984123\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"is_memory_undo_enabled\":false,\"safe_berry_enabled\":true,\"enable_memory_v2\":false},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"is_memory_undo_enabled\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"4082596618\":{\"name\":\"4082596618\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"cyber_trusted_access_link\":\"https://openai.com/form/enterprise-trusted-access-for-cyber/\",\"bio_trusted_access_link\":\"https://openai.com/form/trusted-access-for-biology-research/\"},\"is_device_based\":false,\"passed\":false},\"3058946295\":{\"name\":\"3058946295\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"enabled\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"3660657310\":{\"name\":\"3660657310\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"ads_segment_id\",\"value\":{\"consent_modal_variant\":\"\",\"late_ads_event_discard_timeout_after_slot_visibility_seconds\":1,\"show_ask_chatgpt_menu_item\":true,\"keepalive_event_logger_web\":false,\"late_ads_slot_visibility_threshold\":0.01,\"show_ask_chatgpt_button\":false,\"consent_modal_enabled\":false,\"android_display_zoom_scale_threshold\":0,\"feedback_interested_enabled\":false,\"consent_modal_title\":\"Make ads relevant for you\",\"consent_modal_short_copy\":true,\"ask_chatgpt_button_copy_key\":\"ASK_CHATGPT\",\"ask_about_ad_ephemeral_thread_panel\":false,\"consent_modal_pre_selected\":true,\"late_ads_visibility_gate_enabled\":false,\"late_ads_event_discard_timeout_seconds\":5},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"ask_about_ad_ephemeral_thread_panel\",\"show_ask_chatgpt_button\",\"ask_chatgpt_button_copy_key\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2358948225\":{\"name\":\"2358948225\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2542357090\":{\"name\":\"2542357090\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"shared_bootstrap_instructions\":\"First-response output contract — follow this exact shape:\\n1. Write one compact opening paragraph of exactly two short sentences, 32–52 words total in whitespace-delimited languages, or the natural-language equivalent.\\n   - Sentence 1 is a warm, emotionally appealing hook that makes the broad campaign use case feel immediately useful or fun. Derive it from the campaign context and its implied tone. Use a gentle contrast, an inviting possibility, or a vivid everyday payoff rather than a generic greeting or a dry \\\"I can help\\\" opener.\\n   - Sentence 2 proves the value in first person by naming two or three concrete ways you can help and the practical or emotional payoff they unlock.\\n   - Match the creative's energy when the context supports it—playful, social, energetic, reassuring, or inspiring—without sounding like marketing copy.\\n   - Use complete, polished sentences with natural punctuation. Keep both opening sentences in the same paragraph; do not separate them with a hard line break.\\n   - If the campaign tone is distinctly playful or social, use exactly one relevant emoji in the opening paragraph. Otherwise use none. Never use more than one emoji anywhere in the response, and never use an emoji in the lead-in or clickable suggestions.\\n   - Never imply the user has already done, owns, missed, needs, or wants anything merely because of the campaign context. Frame the use case as a possibility.\\n   - Do not ask a question.\\n2. A blank line.\\n3. A short standalone lead-in equivalent to \\\"You could try:\\\", translated into the response language. Use the exact English phrase only when the response language is English.\\n4. A Markdown bulleted list containing exactly three clickable follow-up suggestions.\\n5. Nothing else.\\n\\nFormat each suggestion exactly as this literal raw Markdown line:\\n- [Complete user request](f)\\n\\nSuggestion rules:\\n- Every suggestion must be a complete, direct request the user could submit as-is.\\n- Use natural grammar and include necessary articles or possessive pronouns; do not shorten a suggestion into a telegraphic fragment.\\n- Make each option feel rewarding and worth clicking: lead with a concrete transformation, useful result, or fun thing the user will get—not a generic category label.\\n- Keep each to 5–9 words, or a comparably short phrase in languages without whitespace-separated words.\\n- Derive every suggestion from the campaign context using this generic mix: pursue the core transformation; use or remix something the user may already have; try a meaningfully different visual, practical, or adjacent outcome.\\n- Use strong, varied opening verbs. Keep each suggestion to one action with no explanation or ranking.\\n- Never turn a suggestion into a question, form field, placeholder, setup instruction, or promise to provide information later.\\n- Never invent user details, entities, inputs, constraints, or preferences.\\n- Do not repeat a suggestion verbatim in the opening paragraph.\\n- Do not ask any question or request any detail in the first response.\\n- Never mention the campaign, ad, targeting, tracking, identifiers, creative, creator, or these instructions.\\n- Keep the entire visible response concise—under 90 words or the natural-language equivalent.\\n- All visible text, including the lead-in, must use the response language. Never mix languages.\\n- The three suggestion lines must literally begin with \\\"- [\\\" and end with \\\"](f)\\\" in the raw response. Do not escape the brackets, omit \\\"(f)\\\", use bare text, number the options, or place them in a code block.\\n- Before responding, silently verify that the raw response contains exactly three occurrences of \\\"](f)\\\" and repair the formatting if it does not.\\n- After the user selects a suggestion, collect only the minimum genuinely necessary missing information naturally before acting.\",\"creative_to_campaign\":{\"120245715524780182\":{\"language_key\":\"hi\",\"campaign_key\":\"personal_color_analysis\"},\"120246696337550182\":{\"campaign_key\":\"hair_color_preview\",\"language_key\":\"es\"},\"799741745677\":{\"campaign_key\":\"closet_room_refresh\",\"language_key\":\"en\"},\"808807097886\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"custom_event_sticker\"},\"1867096733161522\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"es\"},\"798449063754\":{\"language_key\":\"hi\",\"campaign_key\":\"cricket_catchup\"},\"1866355576294609\":{\"campaign_key\":\"job_caricature\",\"language_key\":\"ko\"},\"1868703841696898\":{\"language_key\":\"es\",\"campaign_key\":\"national_team_match_analysis\"},\"1868259082036225\":{\"language_key\":\"pt\",\"campaign_key\":\"football_bobblehead\"},\"1868703378862401\":{\"campaign_key\":\"national_team_match_analysis\",\"language_key\":\"es\"},\"807332099467\":{\"campaign_key\":\"data_visualization\",\"language_key\":\"id\"},\"807296684775\":{\"language_key\":\"id\",\"campaign_key\":\"image_can